# Copy to .env and fill in
DATABASE_URL=postgres://postgres:postgres@localhost:5432/syntegra_mom
JWT_SECRET=change-me-to-a-32-plus-char-random-string-xxxxxxxx
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# Optional: when set, the root URL redirects unauthenticated visitors here
# instead of rendering our built-in landing page. Build-time variable (Vite).
# Set in Railway as VITE_LANDING_URL=https://mom.syntegra.co.id
VITE_LANDING_URL=

# Speech-to-text
GROQ_API_KEY=

# LLM for summarisation. DeepSeek V4 Pro is primary; Claude is optional fallback.
# Set both for automatic failover, or just one.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
ANTHROPIC_API_KEY=

# Transactional email
RESEND_API_KEY=
FROM_EMAIL=noreply@syntegra.co.id

# Midtrans (sandbox by default; set MIDTRANS_PRODUCTION=true for live)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_PRODUCTION=false

# Audio uploads directory (defaults to ./uploads; on Railway use a mounted volume)
AUDIO_DIR=./uploads
