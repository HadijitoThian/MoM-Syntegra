# Copy to .env and fill in
DATABASE_URL=postgres://postgres:postgres@localhost:5432/syntegra_mom
JWT_SECRET=change-me-to-a-32-plus-char-random-string-xxxxxxxx
PORT=3000
NODE_ENV=development
PUBLIC_URL=http://localhost:3000

# External services
GROQ_API_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=noreply@syntegra.co.id

# Midtrans (sandbox by default; set MIDTRANS_PRODUCTION=true for live)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_PRODUCTION=false

# Audio uploads directory (defaults to ./uploads; on Railway use a mounted volume)
AUDIO_DIR=./uploads
